  "channels": [
    {
      "id": "web",
      "name": "Web 界面",
      "description": "通过浏览器访问，最简单的方式",
      "fields": [],
      "is_default": true
    },
    {
      "id": "telegram",
      "name": "Telegram Bot",
      "fields": [
        { "key": "token", "label": "Bot Token", "placeholder": "123456:ABC-DEF", "type": "password", "required": true }
      ],
      "help_doc": "https://core.telegram.org/bots#botfather"
    },
    {
      "id": "feishu",
      "name": "飞书",
      "fields": [
        { "key": "app_id", "label": "App ID", "required": true },
        { "key": "app_secret", "label": "App Secret", "type": "password", "required": true }
      ]
    },
    {
      "id": "qq",
      "name": "QQ",
      "fields": [
        { "key": "bot_id", "label": "Bot ID", "required": true },
        { "key": "bot_secret", "label": "Bot Secret", "type": "password", "required": true }
      ]
    }
